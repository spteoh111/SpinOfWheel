# Public customization values.
# Copy this file to .env.local for local development, .env for Docker Compose,
# or set the same variables in your hosting platform. These values are safe to expose.

NEXT_PUBLIC_APP_NAME="Spin the Wheel"
NEXT_PUBLIC_APP_DESCRIPTION="Pick a random name from a Google Sheet and reveal a YouTube video or message."
NEXT_PUBLIC_SITE_LABEL=""
NEXT_PUBLIC_APP_CREDIT=""
NEXT_PUBLIC_LOGO_SRC="/logo.png"

# Docker/self-hosting options.
APP_PORT=3087
CONTAINER_NAME=spin-of-wheel
